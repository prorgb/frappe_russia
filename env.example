# Скопируйте в .env: cp env.example .env и отредактируйте секреты.

# Домен
DOMAIN=maxon24.online

# ERPNext (официальный образ; MariaDB обязательна для ядра ERPNext)
ERPNEXT_IMAGE=frappe/erpnext
ERPNEXT_TAG=v16.17.0

# MariaDB (ERPNext)
MYSQL_ROOT_PASSWORD=change-me-mariadb-root
MARIADB_ROOT_PASSWORD=change-me-mariadb-root

# Первый сайт Frappe (создаётся: INIT=1 ./run.sh)
FRAPPE_SITE_NAME=erp.maxon24.online
FRAPPE_ADMIN_PASSWORD=change-me-frappe-admin
# Заголовок Host для внутреннего nginx Frappe (по умолчанию $host)
# FRAPPE_SITE_NAME_HEADER=$host

# PostgreSQL (helper-сервисы, не ядро ERPNext)
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=helpers

# Kafka (Bitnami)
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Порты на хосте (0.0.0.0)
HTTP_PORT=80
HTTPS_PORT=443

# Внутренние порты заглушек (менять при подключении реальных образов)
MARKETPLACE_INTERNAL_PORT=8081
OZON_INTERNAL_PORT=8082
FACTORING_INTERNAL_PORT=8083
